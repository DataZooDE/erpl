# name: test/sql/sap_rfc_attach.test
# description: test ATTACH syntax for SAP RFC connections
# group: [rfc]

# Require the RFC extension
require erpl_rfc

# Configure connection ------------------------------------------------
require-env ERPL_SAP_ASHOST

require-env ERPL_SAP_SYSNR

require-env ERPL_SAP_USER

require-env ERPL_SAP_PASSWORD

require-env ERPL_SAP_CLIENT

require-env ERPL_SAP_LANG

statement ok
CREATE SECRET abap_trial (
    TYPE sap_rfc,
    ASHOST '${ERPL_SAP_ASHOST}',
    SYSNR '${ERPL_SAP_SYSNR}',
    CLIENT '${ERPL_SAP_CLIENT}',
    USER '${ERPL_SAP_USER}',
    PASSWD '${ERPL_SAP_PASSWORD}',
    LANG '${ERPL_SAP_LANG}'
);

# ---------------------------------------------------------------------
# Test 1: Basic ATTACH with SECRET succeeds
statement ok
ATTACH '' AS sap (TYPE sap_rfc, SECRET 'abap_trial');

# ---------------------------------------------------------------------
# Test 2: Query a table through the attached catalog
query I
SELECT COUNT(*) > 0 FROM sap."/DMO/FLIGHT";
----
true

# ---------------------------------------------------------------------
# Test 3: DETACH works
statement ok
DETACH sap;

# ---------------------------------------------------------------------
# Test 4: ATTACH with TABLES list - only listed tables are accessible
statement ok
ATTACH '' AS sap2 (TYPE sap_rfc, SECRET 'abap_trial', TABLES '/DMO/FLIGHT,/DMO/CARRIER');

query I
SELECT COUNT(*) > 0 FROM sap2."/DMO/FLIGHT";
----
true

# ---------------------------------------------------------------------
# Test 5: ATTACH with TABLES - unlisted table returns error
statement error
SELECT * FROM sap2.T001;
----
Catalog Error

statement ok
DETACH sap2;

# ---------------------------------------------------------------------
# Test 6: ATTACH without SECRET uses default secret
statement ok
ATTACH '' AS sap3 (TYPE sap_rfc);

query I
SELECT COUNT(*) > 0 FROM sap3."/DMO/FLIGHT";
----
true

statement ok
DETACH sap3;

# ---------------------------------------------------------------------
# Test 7: ATTACH with non-existent secret name errors
statement error
ATTACH '' AS sap4 (TYPE sap_rfc, SECRET 'nonexistent_secret');
----
Invalid Input Error

# ---------------------------------------------------------------------
# Test 8: Re-attach with same alias after detach
statement ok
ATTACH '' AS sap5 (TYPE sap_rfc, SECRET 'abap_trial');

query I
SELECT COUNT(*) > 0 FROM sap5."/DMO/FLIGHT";
----
true

statement ok
DETACH sap5;

statement ok
ATTACH '' AS sap5 (TYPE sap_rfc, SECRET 'abap_trial');

query I
SELECT COUNT(*) > 0 FROM sap5."/DMO/FLIGHT";
----
true

statement ok
DETACH sap5;

# ---------------------------------------------------------------------
# Test 9: JOIN across tables in attached catalog
statement ok
ATTACH '' AS sap6 (TYPE sap_rfc, SECRET 'abap_trial');

query I
SELECT COUNT(*) > 0
FROM sap6."/DMO/FLIGHT" f
JOIN sap6."/DMO/CARRIER" c ON f.CARRIER_ID = c.CARRIER_ID;
----
true

statement ok
DETACH sap6;

# ---------------------------------------------------------------------
# Test 10: Filter pushdown through attached catalog
statement ok
ATTACH '' AS sap7 (TYPE sap_rfc, SECRET 'abap_trial');

query I
SELECT COUNT(*) >= 0 FROM sap7."/DMO/FLIGHT" WHERE CARRIER_ID = 'LH';
----
true

statement ok
DETACH sap7;

# ---------------------------------------------------------------------
# Test 11: TABLES list - second entry is also accessible
statement ok
ATTACH '' AS sap8 (TYPE sap_rfc, SECRET 'abap_trial', TABLES '/DMO/FLIGHT,/DMO/CARRIER');

query I
SELECT COUNT(*) > 0 FROM sap8."/DMO/CARRIER";
----
true

statement ok
DETACH sap8;

# ---------------------------------------------------------------------
# Test 12: Column projection through attached catalog
statement ok
ATTACH '' AS sap9 (TYPE sap_rfc, SECRET 'abap_trial');

query I
SELECT COUNT(*) FROM (SELECT CARRIER_ID, CONNECTION_ID FROM sap9."/DMO/FLIGHT" LIMIT 1);
----
1

statement ok
DETACH sap9;

# ---------------------------------------------------------------------
# Test 13: SHOW TABLES lists tables when TABLES option is set
statement ok
ATTACH '' AS sap10 (TYPE sap_rfc, SECRET 'abap_trial', TABLES '/DMO/FLIGHT,/DMO/CARRIER');

query I
SELECT COUNT(*) FROM (SHOW TABLES FROM sap10);
----
2

statement ok
DETACH sap10;

# ---------------------------------------------------------------------
# Test 14: Catalog scan does not permanently disable DefaultGenerator (issue #54)
#
# When another extension (e.g. Ducklake) is attached it may trigger a full
# Scan() of every attached catalog's VIEW_ENTRY CatalogSet.  Before the fix,
# CreateDefaultEntries() set created_all_entries=true even when
# GetDefaultEntries() returned [] (the case when no TABLES option is given).
# That permanently bypassed GetEntryDefault() so subsequent SAP table lookups
# failed with "Catalog Error: Table … does not exist."
#
# With the fix, created_all_entries is only set after a non-empty
# GetDefaultEntries() list has been fully materialised.

statement ok
ATTACH '' AS sap_issue54 (TYPE sap_rfc, SECRET 'abap_trial');

# Trigger a full scan of the attached SAP catalog (simulates Ducklake attach).
# information_schema.tables calls Scan() on VIEW_ENTRY for every catalog.
query I
SELECT COUNT(*) >= 0 FROM information_schema.tables WHERE table_catalog = 'sap_issue54';
----
true

# Table lookup must still succeed after the scan (regression for issue #54).
query I
SELECT COUNT(*) > 0 FROM sap_issue54."/DMO/FLIGHT";
----
true

statement ok
DETACH sap_issue54;

# ---------------------------------------------------------------------
# Test 15: TABLES wildcard pattern populates SHOW TABLES (issue #70)
#
# Without TABLES, SHOW TABLES on an attached SAP catalog was empty because
# the catalog cannot enumerate the tens of thousands of SAP tables.  TABLES
# now accepts glob patterns (`*`, `?`); SHOW TABLES then lists exactly the
# resolved set, scoped to a bounded, meaningful subset.

statement ok
ATTACH '' AS sap_pat (TYPE sap_rfc, SECRET 'abap_trial', TABLES '/DMO/*');

# The pattern resolves to many tables (48 on the ABAP trial); assert it is
# non-empty rather than an exact count so the test stays portable.
query I
SELECT COUNT(*) >= 2 FROM (SHOW TABLES FROM sap_pat);
----
true

# A specific known table is present in the listing.
query I
SELECT COUNT(*) FROM (SHOW TABLES FROM sap_pat) WHERE "name" = '/DMO/FLIGHT';
----
1

# A pattern-matched table is queryable through the attached catalog.
query I
SELECT COUNT(*) > 0 FROM sap_pat."/DMO/FLIGHT";
----
true

# A table outside the pattern is NOT accessible (the pattern scopes the catalog).
statement error
SELECT * FROM sap_pat."DD02L";
----
Catalog Error

statement ok
DETACH sap_pat;

# ---------------------------------------------------------------------
# Test 16: TABLES mixes exact names and patterns; duplicates collapse
statement ok
ATTACH '' AS sap_mix (TYPE sap_rfc, SECRET 'abap_trial', TABLES '/DMO/CARRIER,/DMO/*');

# /DMO/CARRIER is matched by both the exact entry and the pattern but appears once.
query I
SELECT COUNT(*) FROM (SHOW TABLES FROM sap_mix) WHERE "name" = '/DMO/CARRIER';
----
1

query I
SELECT COUNT(*) >= 2 FROM (SHOW TABLES FROM sap_mix);
----
true

statement ok
DETACH sap_mix;
